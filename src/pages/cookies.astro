---
// CookieBanner.astro
---

<div id="cookie-overlay" class="cookie-overlay hidden">
  <!-- Banner principal -->
  <div id="cookie-banner" class="cookie-box">
    <h2>Uso de Cookies 🍪</h2>
    <p>Utilizamos cookies propias y de terceros para mejorar nuestros servicios, analizar el tráfico y personalizar el contenido. Puedes aceptarlas todas, configurarlas o rechazarlas.</p>
    <p class="warning-text">⚠️ <strong>Aviso:</strong> Si decides rechazarlas, no podrás seguir navegando por la web.</p>
    
    <div class="cookie-buttons">
      <button id="btn-accept-all" class="btn btn-primary">Aceptar Todas</button>
      <button id="btn-config" class="btn btn-secondary">Configurar</button>
      <button id="btn-reject" class="btn btn-danger">Rechazar</button>
    </div>
  </div>

  <!-- Modal de configuración -->
  <div id="cookie-settings" class="cookie-box hidden">
    <h2>Configuración de Cookies</h2>
    <p>Selecciona qué cookies quieres permitir:</p>
    
    <div class="cookie-option">
      <div class="cookie-option-text">
        <strong>Técnicas (Necesarias)</strong>
        <span>Imprescindibles para que la web funcione (no se pueden desactivar).</span>
      </div>
      <input type="checkbox" checked disabled />
    </div>
    
    <div class="cookie-option">
      <div class="cookie-option-text">
        <strong>Analíticas</strong>
        <span>Nos ayudan a saber cuánta gente nos visita (estadísticas).</span>
      </div>
      <input type="checkbox" id="chk-analytics" checked />
    </div>
    
    <div class="cookie-option">
      <div class="cookie-option-text">
        <strong>Marketing</strong>
        <span>Para mostrar contenido o anuncios relevantes.</span>
      </div>
      <input type="checkbox" id="chk-marketing" checked />
    </div>

    <div class="cookie-buttons mt-4">
      <button id="btn-save-settings" class="btn btn-primary">Guardar Preferencias</button>
      <button id="btn-back-settings" class="btn btn-secondary">Atrás</button>
    </div>
  </div>

  <!-- Modal de rechazo (Bloqueo Total) -->
  <div id="cookie-rejected" class="cookie-box hidden text-center">
    <h2>Acceso Bloqueado 🚫</h2>
    <p>Has decidido rechazar las cookies.</p>
    <p>Para poder disfrutar de nuestro contenido y navegar por <strong>Trucos125</strong>, es necesario aceptar al menos las condiciones de navegación.</p>
    <button id="btn-back-rejected" class="btn btn-primary mt-4">Volver a las opciones</button>
  </div>
</div>

<script is:inline>
  // Usamos astro:page-load para que funcione perfectamente con las transiciones de Astro (ViewTransitions)
  document.addEventListener('astro:page-load', () => {
    const overlay = document.getElementById('cookie-overlay');
    const banner = document.getElementById('cookie-banner');
    const settings = document.getElementById('cookie-settings');
    const rejected = document.getElementById('cookie-rejected');
    
    const btnAcceptAll = document.getElementById('btn-accept-all');
    const btnReject = document.getElementById('btn-reject');
    const btnConfig = document.getElementById('btn-config');
    const btnSaveSettings = document.getElementById('btn-save-settings');
    const btnBackSettings = document.getElementById('btn-back-settings');
    const btnBackRejected = document.getElementById('btn-back-rejected');

    const chkAnalytics = document.getElementById('chk-analytics');
    const chkMarketing = document.getElementById('chk-marketing');

    // Comprobamos si el usuario ya ha tomado una decisión
    const consent = localStorage.getItem('cookieConsent');
    
    if (!consent) {
      // Si no hay decisión, mostramos el banner y bloqueamos el scroll
      overlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    } else if (consent === 'rejected') {
      // Si ya las rechazó en el pasado, lo mantenemos bloqueado
      overlay.classList.remove('hidden');
      banner.classList.add('hidden');
      rejected.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    // ACCIÓN: Aceptar Todas
    btnAcceptAll?.addEventListener('click', () => {
      localStorage.setItem('cookieConsent', 'all');
      localStorage.setItem('cookieAnalytics', 'true');
      localStorage.setItem('cookieMarketing', 'true');
      closeOverlay();
    });

    // ACCIÓN: Rechazar (Muro de bloqueo)
    btnReject?.addEventListener('click', () => {
      localStorage.setItem('cookieConsent', 'rejected');
      banner.classList.add('hidden');
      rejected.classList.remove('hidden');
      // No restauramos el scroll, se queda bloqueado.
    });

    // ACCIÓN: Botón "Configurar"
    btnConfig?.addEventListener('click', () => {
      banner.classList.add('hidden');
      settings.classList.remove('hidden');
    });

    // ACCIÓN: Guardar configuración personalizada
    btnSaveSettings?.addEventListener('click', () => {
      localStorage.setItem('cookieConsent', 'custom');
      localStorage.setItem('cookieAnalytics', chkAnalytics.checked);
      localStorage.setItem('cookieMarketing', chkMarketing.checked);
      closeOverlay();
    });

    // Botones para volver atrás en los menús
    btnBackSettings?.addEventListener('click', () => {
      settings.classList.add('hidden');
      banner.classList.remove('hidden');
    });

    btnBackRejected?.addEventListener('click', () => {
      rejected.classList.add('hidden');
      banner.classList.remove('hidden');
    });

    function closeOverlay() {
      overlay.classList.add('hidden');
      document.body.style.overflow = ''; // Devolvemos el scroll a la página
    }
  });
</script>

<style>
  /* Fondo oscuro que bloquea absolutamente todo */
  .cookie-overlay {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(8px);
    z-index: 999999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .cookie-overlay.hidden {
    display: none !important;
  }
  
  /* Cajas de diálogo */
  .cookie-box {
    background: #fff;
    max-width: 600px;
    width: 100%;
    padding: 35px;
    border-radius: 12px;
    box-shadow: 0 10px 50px rgba(0,0,0,0.5);
    font-family: 'Roboto', sans-serif;
  }
  .cookie-box.hidden {
    display: none;
  }

  .cookie-box h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2.5rem;
    margin-top: 0;
    margin-bottom: 15px;
    color: #111;
    text-transform: uppercase;
  }

  .cookie-box p {
    font-size: 1.1rem;
    color: #444;
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .warning-text {
    color: #e30613 !important;
    font-weight: 500;
  }

  /* Botones */
  .cookie-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: flex-end;
    margin-top: 10px;
  }

  .btn {
    padding: 12px 24px;
    border: none;
    border-radius: 6px;
    font-size: 1.1rem;
    font-weight: bold;
    cursor: pointer;
    transition: transform 0.2s ease, background 0.2s;
    font-family: 'Barlow Condensed', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-primary { background: #e30613; color: #fff; }
  .btn-primary:hover { background: #b3040f; }
  
  .btn-secondary { background: #f4f4f4; color: #333; border: 1px solid #ddd; }
  .btn-secondary:hover { background: #e5e5e5; }

  .btn-danger { background: #111; color: #fff; }
  .btn-danger:hover { background: #333; }

  /* Opciones de configuración */
  .cookie-option {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 0;
    border-bottom: 1px solid #eee;
  }
  .cookie-option:last-of-type { border-bottom: none; }

  .cookie-option-text {
    display: flex;
    flex-direction: column;
    padding-right: 20px;
  }
  .cookie-option-text strong { color: #111; font-size: 1.1rem; }
  .cookie-option-text span { color: #666; font-size: 0.95rem; margin-top: 4px; }

  .mt-4 { margin-top: 25px; }
  .text-center { text-align: center; }
  .text-center .cookie-buttons { justify-content: center; }

  input[type="checkbox"] {
    width: 24px;
    height: 24px;
    cursor: pointer;
    accent-color: #e30613;
  }
  
  @media (max-width: 600px) {
    .cookie-buttons { flex-direction: column; }
    .btn { width: 100%; text-align: center; }
  }
</style>
