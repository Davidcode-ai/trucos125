---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`Contacto - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="container">
			<section class="contact-wrapper">
				<div class="contact-info">
					<span class="badge red">Hablemos</span>
					<h1>¿TIENES ALGUNA DUDA SOBRE TU 125CC?</h1>
					<p>Si quieres colaborar, tienes dudas técnicas o simplemente quieres saludar a otro apasionado de las dos ruedas, escríbeme.</p>
					
					<div class="info-item">
						<strong>EMAIL DIRECTO:</strong>
						<p>hola@trucos125.com</p>
					</div>
					<div class="info-item">
						<strong>REDES SOCIALES:</strong>
						<p>@trucos125</p>
					</div>
				</div>

				<div class="contact-form-card">
					<form action="#" method="POST" class="form">
						<div class="form-group">
							<label>Tu nombre</label>
							<input type="text" placeholder="Ej. Juan Pérez" required />
						</div>
						<div class="form-group">
							<label>Email de contacto</label>
							<input type="email" placeholder="tu@email.com" required />
						</div>
						<div class="form-group">
							<label>¿En qué puedo ayudarte?</label>
							<textarea rows="5" placeholder="Cuéntame tu duda..."></textarea>
						</div>
						<button type="submit" class="btn-send">ENVIAR MENSAJE</button>
					</form>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.container { max-width: 1100px; margin: 0 auto; padding: 60px 20px; }
	
	.contact-wrapper {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		align-items: center;
	}

	.contact-info h1 {
		font-family: 'Barlow Condensed', sans-serif;
		font-size: 3.5rem;
		font-weight: 900;
		line-height: 1;
		margin: 20px 0;
	}

	.badge.red { background: #e30613; color: white; padding: 5px 12px; font-weight: 800; text-transform: uppercase; font-size: 0.9rem; }

	.info-item { margin-top: 30px; }
	.info-item strong { display: block; font-family: 'Barlow Condensed', sans-serif; font-size: 1.2rem; color: #e30613; }
	.info-item p { font-size: 1.3rem; font-weight: 600; margin: 5px 0; }

	/* Estilos del Formulario */
	.contact-form-card {
		background: #f9fafb;
		padding: 40px;
		border-radius: 15px;
		border: 1px solid #eee;
		box-shadow: 0 10px 30px rgba(0,0,0,0.05);
	}

	.form-group { margin-bottom: 20px; }
	.form-group label { display: block; font-weight: 700; margin-bottom: 8px; font-family: 'Barlow Condensed', sans-serif; text-transform: uppercase; }
	
	input, textarea {
		width: 100%;
		padding: 12px;
		border: 1px solid #ddd;
		border-radius: 8px;
		font-size: 1rem;
		font-family: inherit;
	}

	.btn-send {
		width: 100%;
		background: #111;
		color: white;
		border: none;
		padding: 15px;
		font-family: 'Barlow Condensed', sans-serif;
		font-size: 1.3rem;
		font-weight: 800;
		cursor: pointer;
		border-radius: 8px;
		transition: background 0.2s, transform 0.2s;
	}

	.btn-send:hover { background: #e30613; transform: scale(1.02); }

	@media (max-width: 768px) {
		.contact-wrapper { grid-template-columns: 1fr; gap: 40px; }
		.contact-info h1 { font-size: 2.5rem; }
	}
</style>