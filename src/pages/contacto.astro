---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={`Contacto - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    </head>
    <body class="page-wrapper">
        <Header />
        <main class="container">
            <section class="contact-wrapper">
                <div class="contact-info">
                    <span class="badge red">Hablemos</span>
                    <h1>¿TIENES ALGUNA DUDA SOBRE TU 125CC?</h1>
                    <p>Si quieres colaborar, tienes dudas técnicas o simplemente quieres saludar a otro apasionado de las dos ruedas, escríbeme.</p>
                    
                    <div class="info-item">
                        <strong>EMAIL DIRECTO:</strong>
                        <p>hola@trucos125.com</p>
                    </div>
                    <div class="info-item">
                        <strong>REDES SOCIALES:</strong>
                        <div class="social-icons">
                            <a href="https://instagram.com/trucos125_" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                            </a>
                            <a href="https://www.facebook.com/profile.php?id=61582252036670" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                            </a>
                            <a href="https://x.com/Trucos125" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
                                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733 -16z"></path><path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"></path></svg>
                            </a>
                            <a href="https://youtube.com/@Trucos125" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
                            </a>
                            <a href="https://tiktok.com/@trucos125_" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
                                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
                            </a>
                        </div>
                    </div>
                </div>

                <div class="contact-form-card">
                    <form action="https://api.web3forms.com/submit" method="POST" class="form">
                        <input type="hidden" name="access_key" value="9c03786c-6fd9-4e7c-9ad6-62f33fd5ceba">
                        <input type="hidden" name="subject" value="Nuevo mensaje desde la web Trucos125">
                        <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

                        <div class="form-group">
                            <label>Tu nombre</label>
                            <input type="text" name="name" placeholder="Ej. Juan Pérez" required />
                        </div>
                        <div class="form-group">
                            <label>Email de contacto</label>
                            <input type="email" name="email" placeholder="tu@email.com" required />
                        </div>
                        <div class="form-group">
                            <label>¿En qué puedo ayudarte?</label>
                            <textarea name="message" rows="5" placeholder="Cuéntame tu duda..." required></textarea>
                        </div>
                        <button type="submit" class="btn-send">ENVIAR MENSAJE</button>
                    </form>
                </div>
            </section>
        </main>
        <Footer />
    </body>
</html>

<style>
    /* --- TRUCO PARA MANTENER EL FOOTER ABAJO --- */
    html, body {
        height: 100%;
        margin: 0;
    }
    .page-wrapper {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }
    .container { 
        flex: 1; /* Esto empuja el footer hacia abajo */
        width: 100%;
        max-width: 1100px; 
        margin: 0 auto; 
        padding: 60px 20px; 
        box-sizing: border-box;
    }
    
    .contact-wrapper {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
    }

    .contact-info h1 {
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 3.5rem;
        font-weight: 900;
        line-height: 1;
        margin: 20px 0;
    }

    .badge.red { background: #111; color: white; padding: 5px 12px; font-weight: 800; text-transform: uppercase; font-size: 0.9rem; border-radius: 4px; display: inline-block;}

    .info-item { margin-top: 30px; }
    .info-item strong { display: block; font-family: 'Barlow Condensed', sans-serif; font-size: 1.2rem; color: #e30613; margin-bottom: 5px; }
    .info-item p { font-size: 1.3rem; font-weight: 600; margin: 0; }

    /* Estilos Redes Sociales */
    .social-icons {
        display: flex;
        gap: 15px;
        margin-top: 10px;
    }
    .social-icons a {
        color: #111;
        transition: color 0.2s ease, transform 0.2s ease;
    }
    .social-icons a:hover {
        color: #e30613;
        transform: translateY(-3px);
    }

    /* Estilos del Formulario */
    .contact-form-card {
        background: #f9fafb;
        padding: 40px;
        border-radius: 15px;
        border: 1px solid #eee;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; font-weight: 700; margin-bottom: 8px; font-family: 'Barlow Condensed', sans-serif; text-transform: uppercase; }
    
    input, textarea {
        width: 100%;
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 1rem;
        font-family: inherit;
        box-sizing: border-box; 
    }

    input:focus, textarea:focus { outline: none; border-color: #e30613; }

    .btn-send {
        width: 100%;
        background: #e30613;
        color: white;
        border: none;
        padding: 15px;
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 1.3rem;
        font-weight: 800;
        cursor: pointer;
        border-radius: 8px;
        transition: background 0.2s, transform 0.2s;
        margin-top: 10px;
    }

    .btn-send:hover { background: #be123c; transform: translateY(-2px); }

    @media (max-width: 768px) {
        .contact-wrapper { grid-template-columns: 1fr; gap: 40px; }
        .contact-info h1 { font-size: 2.5rem; }
        .contact-form-card { padding: 25px; }
    }
</style>