---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import CalculadoraAhorro from '../components/CalculadoraAhorro.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Los 3 artículos más nuevos para la sección de abajo
const latestPosts = allPosts.slice(0, 3);

// --- MAGIA PARA LA CABECERA ---
// Buscamos los artículos por alguna palabra clave de su archivo. 
// Si no los encuentra, coge el 1º, 2º y 3º por defecto para que la web nunca se rompa.
const postPrincipal = allPosts.find(p => p.id.includes('velocidad') || p.id.includes('corra-mas')) || allPosts[0];
const postMecanica = allPosts.find(p => p.id.includes('rodaje')) || allPosts[1];
const postConsejos = allPosts.find(p => p.id.includes('scooter') || p.id.includes('marchas')) || allPosts[2];
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
    <body>
        <Header />
        
        <main>
            <div class="container">
                
                <section class="hero-grid">
                    
                    <article class="grid-item main-story">
                        <a href={`/blog/${postPrincipal.id}/`} class="img-link zoom-effect">
                            <span class="badge red">DESTACADO</span>
                            {postPrincipal.data.heroImage ? (
                                <img src={postPrincipal.data.heroImage.src} alt={postPrincipal.data.title} />
                            ) : (
                                <div style="width:100%; height:100%; background:#333;"></div>
                            )}
                            <div class="overlay">
                                <h1>{postPrincipal.data.title}</h1>
                                <p>{postPrincipal.data.description}</p>
                            </div>
                        </a>
                    </article>

                    <div class="side-column">
                        
                        <article class="grid-item side-story">
                            <a href={`/blog/${postMecanica.id}/`} class="img-link zoom-effect">
                                <span class="badge black">MECÁNICA</span>
                                {postMecanica.data.heroImage ? (
                                    <img src={postMecanica.data.heroImage.src} alt={postMecanica.data.title} />
                                ) : (
                                    <div style="width:100%; height:100%; background:#333;"></div>
                                )}
                                <div class="overlay small">
                                    <h3>{postMecanica.data.title}</h3>
                                </div>
                            </a>
                        </article>

                        <article class="grid-item side-story">
                            <a href={`/blog/${postConsejos.id}/`} class="img-link zoom-effect">
                                <span class="badge black">CONSEJOS</span>
                                {postConsejos.data.heroImage ? (
                                    <img src={postConsejos.data.heroImage.src} alt={postConsejos.data.title} />
                                ) : (
                                    <div style="width:100%; height:100%; background:#333;"></div>
                                )}
                                <div class="overlay small">
                                    <h3>{postConsejos.data.title}</h3>
                                </div>
                            </a>
                        </article>
                    </div>
                </section>

                <CalculadoraAhorro />
                <br>

                <section class="news-section">
                    <div class="section-title">
                        <h2>ÚLTIMAS PRUEBAS Y NOVEDADES</h2>
                        <div class="title-line"></div>
                    </div>

                    <div class="news-grid">
                        {
                            latestPosts.map((post) => (
                                <article class="news-card">
                                    <a href={`/blog/${post.id}/`} class="card-img zoom-effect">
                                        <span class="badge red">NUEVO</span>
                                        {post.data.heroImage ? (
                                            <img src={post.data.heroImage.src} alt={post.data.title} />
                                        ) : (
                                            <div style="width:100%; height:100%; background:#333;"></div>
                                        )}
                                    </a>
                                    <div class="card-content">
                                        <h3>{post.data.title}</h3>
                                    </div>
                                </article>
                            ))
                        }
                    </div>
                </section>

            </div>
        </main>
        <Footer />
    </body>
</html>

<style>
    /* --- ESTILOS CRÍTICOS PARA LA PORTADA --- */
    
    .container {
        max-width: 1280px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    h1, h2, h3, .badge {
        font-family: 'Barlow Condensed', sans-serif;
        text-transform: uppercase;
        font-weight: 800;
        line-height: 1;
        margin: 0;
    }

    .hero-grid {
        display: grid;
        grid-template-columns: 2fr 1fr; 
        gap: 20px;
        height: 550px; 
        margin-bottom: 60px;
    }

    .side-column {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .grid-item {
        position: relative;
        height: 100%;
        width: 100%;
        overflow: hidden;
        background: #111; 
    }

    .side-story {
        flex: 1; 
    }

    .img-link {
        display: block;
        width: 100%;
        height: 100%;
        position: relative;
    }

    .img-link img {
        width: 100%;
        height: 100%;
        object-fit: cover; 
        transition: transform 0.6s ease, opacity 0.6s ease;
        opacity: 0.95;
    }

    .zoom-effect:hover img {
        transform: scale(1.08); 
        opacity: 0.8; 
    }

    .overlay {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        padding: 30px;
        background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.5) 60%, transparent 100%);
        pointer-events: none; 
    }

    .overlay h1, .overlay h3 {
        color: white; 
        text-shadow: 2px 2px 6px rgba(0,0,0,0.9); 
        margin-bottom: 10px;
    }

    .overlay h1 {
        font-size: 2.8rem;
    }

    .overlay p {
        color: #f8f9fa; 
        font-size: 1.1rem;
        font-weight: 600;
        margin: 0;
        text-shadow: 1px 1px 4px rgba(0,0,0,0.9);
    }

    .overlay.small { padding: 20px; }
    .overlay.small h3 { font-size: 1.6rem; }
    
    .badge {
        position: absolute;
        top: 15px; left: 15px;
        padding: 5px 12px;
        font-size: 0.9rem;
        color: white;
        z-index: 10;
        box-shadow: 2px 2px 0 rgba(0,0,0,0.2);
    }
    .badge.red { background-color: #e30613; }
    .badge.black { background-color: #111; }

    .section-title {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 30px;
    }
    .section-title h2 { font-size: 2.2rem; color: #111; white-space: nowrap; }
    .title-line { width: 100%; height: 4px; background-color: #e30613; }

    .news-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
    }

    .news-card .card-img {
        display: block;
        height: 220px;
        position: relative;
        overflow: hidden;
        margin-bottom: 15px;
        background: #111;
        border-radius: 8px; 
    }

    .card-content h3 {
        font-size: 1.4rem;
        color: #111;
        transition: color 0.2s;
        font-family: 'Barlow Condensed', sans-serif;
        font-weight: 800;
        text-transform: uppercase;
        line-height: 1.2;
    }
    .news-card:hover .card-content h3 {
        color: #e30613; 
    }

    @media (max-width: 768px) {
        .hero-grid {
            grid-template-columns: 1fr; 
            height: auto; 
        }
        .main-story { height: 400px; margin-bottom: 20px; }
        .side-column { height: auto; gap: 20px; }
        .side-story { height: 250px; }
        
        .overlay h1 { font-size: 2rem; }
        
        .news-grid {
            grid-template-columns: 1fr; 
        }
    }
</style>