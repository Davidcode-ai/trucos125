---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Filtramos SOLO los de Equipamiento
const postsEquipamiento = posts.filter((post) => post.data.categoria === 'Equipamiento');
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={`Equipamiento | ${SITE_TITLE}`} description="Guías de compra, cascos, chaquetas y el mejor equipamiento para motos de 125cc." />
    </head>
    <body>
        <Header />
        <main>
            <h1>Guías de Compra y Equipamiento</h1>
            <section>
                <ul>
                    {
                        postsEquipamiento.map((post) => (
                            <li>
                                <a href={`/blog/${post.id}/`}>
                                    <h4 class="title">{post.data.title}</h4>
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </section>
        </main>
        <Footer />
    </body>
</html>