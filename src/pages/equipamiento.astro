---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

// 1. Traemos todos los artículos y los ordenamos por fecha
const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// 2. Filtramos SOLO los de Equipamiento
const filteredPosts = posts.filter((post) => post.data.categoria === 'Equipamiento');
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={`Equipamiento - ${SITE_TITLE}`} description="Guías de compra, cascos, chaquetas y el mejor equipamiento para motos de 125cc." />
    </head>
    <body>
        <Header />
        <main class="container">
            <section class="page-header">
                <h1>GUÍAS Y EQUIPAMIENTO</h1>
                <div class="title-line"></div>
                <p>Descubre los mejores cascos, chaquetas, guantes y accesorios para tu 125cc.</p>
                
                <div class="search-wrapper">
                    <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    <input type="text" id="buscador-articulos" placeholder="Buscar cascos, guantes, motos..." autocomplete="off" />
                </div>

                <nav class="category-nav">
                    <a href="/blog" class="category-pill">Todos</a>
                    <a href="/mecanica" class="category-pill">🔧 Mecánica</a>
                    <a href="/conduccion" class="category-pill">🏍️ Conducción</a>
                    <a href="/equipamiento" class="category-pill active">🪖 Equipamiento</a>
                    <a href="/normativa" class="category-pill">🏙️ Normativa</a>
                </nav>
            </section>

            <section>
                <ul class="blog-grid" id="lista-articulos">
                    {
                        filteredPosts.map((post) => (
                            <li class="articulo-item">
                                <article class="post-card">
                                    <a href={`/blog/${post.id}/`} class="img-container">
                                        {post.data.heroImage ? (
                                            <img src={post.data.heroImage.src} alt={post.data.title} />
                                        ) : (
                                            <div class="no-img">Sin imagen</div>
                                        )}
                                    </a>
                                    
                                    <div class="post-content">
                                        <p class="date">
                                            <FormattedDate date={post.data.pubDate} />
                                            <span class="sep">|</span>
                                            <a href={`/blog/${post.id}/#disqus_thread`} class="comment-link">0 Comentarios</a>
                                        </p>
                                        
                                        <a href={`/blog/${post.id}/`} class="title-link">
                                            <h4 class="title">{post.data.title}</h4>
                                        </a>
                                    </div>
                                </article>
                            </li>
                        ))
                    }
                </ul>
                <div id="no-resultados" style="display: none; text-align: center; padding: 40px; color: #666; font-size: 1.2rem;">
                    No hemos encontrado ningún artículo con esa palabra en esta categoría. 🏍️
                </div>
            </section>
        </main>
        <Footer />

        <script is:inline>
            document.addEventListener('astro:page-load', () => {
                const buscador = document.getElementById('buscador-articulos');
                const articulos = document.querySelectorAll('.articulo-item');
                const mensajeVacio = document.getElementById('no-resultados');

                if (buscador) {
                    buscador.addEventListener('input', (e) => {
                        const textoBusqueda = e.target.value.toLowerCase();
                        let contadorVisibles = 0;

                        articulos.forEach(articulo => {
                            const titulo = articulo.querySelector('.title').textContent.toLowerCase();
                            if (titulo.includes(textoBusqueda)) {
                                articulo.style.display = 'block';
                                contadorVisibles++;
                            } else {
                                articulo.style.display = 'none';
                            }
                        });

                        if (contadorVisibles === 0) {
                            mensajeVacio.style.display = 'block';
                        } else {
                            mensajeVacio.style.display = 'none';
                        }
                    });
                }
            });
        </script>
    </body>
</html>

<style>
    /* --- ESTRUCTURA PRINCIPAL --- */
    .container { max-width: 1200px; margin: 0 auto; padding: 40px 20px; }

    /* --- CABECERA DE LA PÁGINA --- */
    .page-header { text-align: center; margin-bottom: 50px; }
    .page-header h1 { font-family: 'Barlow Condensed', sans-serif; font-size: 3.5rem; font-weight: 900; color: #111; margin: 0; letter-spacing: -1px; text-transform: uppercase; }
    .title-line { width: 80px; height: 5px; background-color: #e30613; margin: 15px auto; }
    .page-header p { color: #555; font-size: 1.2rem; font-weight: 500; margin-bottom: 30px; }

    /* --- ESTILOS DEL BUSCADOR --- */
    .search-wrapper { position: relative; max-width: 600px; margin: 0 auto; }
    .search-icon { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #888; }
    #buscador-articulos { width: 100%; padding: 16px 20px 16px 50px; font-size: 1.1rem; border: 2px solid #eee; border-radius: 50px; box-sizing: border-box; transition: all 0.3s ease; outline: none; box-shadow: 0 4px 15px rgba(0,0,0,0.03); font-family: inherit; }
    #buscador-articulos:focus { border-color: #e30613; box-shadow: 0 4px 20px rgba(227, 6, 19, 0.1); }

    /* --- ESTILOS DE LOS BOTONES DE CATEGORÍAS --- */
    .category-nav { display: flex; flex-wrap: wrap; gap: 15px; justify-content: center; margin-top: 35px; }
    .category-pill { background-color: #f4f4f4; color: #111; padding: 10px 22px; border-radius: 30px; text-decoration: none; font-weight: bold; font-family: 'Barlow Condensed', sans-serif; font-size: 1.1rem; text-transform: uppercase; letter-spacing: 1px; transition: all 0.3s ease; border: 2px solid transparent; }
    .category-pill:hover, .category-pill.active { background-color: #fff; border-color: #e30613; color: #e30613; transform: translateY(-2px); box-shadow: 0 4px 10px rgba(227, 6, 19, 0.15); }

    /* --- GRID DE ARTÍCULOS --- */
    .blog-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 35px; list-style-type: none; margin: 0; padding: 0; }

    /* --- TARJETAS DE LOS ARTÍCULOS --- */
    .post-card { display: flex; flex-direction: column; background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.06); transition: transform 0.3s ease, box-shadow 0.3s ease; height: 100%; border: 1px solid #eee; }
    .post-card:hover { transform: translateY(-8px); box-shadow: 0 15px 30px rgba(0,0,0,0.12); }
    .img-container, .title-link { text-decoration: none; }
    .img-container { width: 100%; aspect-ratio: 16 / 9; overflow: hidden; background-color: #111; position: relative; display: block; }
    .img-container img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
    .post-card:hover .img-container img { transform: scale(1.08); }
    .no-img { display: flex; align-items: center; justify-content: center; height: 100%; color: white; font-weight: bold; }

    /* --- TEXTOS DE LA TARJETA --- */
    .post-content { padding: 25px 20px; display: flex; flex-direction: column; flex-grow: 1; }
    .date { margin: 0 0 12px 0; color: #888; font-size: 0.9rem; text-transform: uppercase; font-weight: 700; letter-spacing: 1px; display: flex; align-items: center; }
    .title { margin: 0; color: #111; font-size: 1.6rem; line-height: 1.2; font-family: 'Barlow Condensed', sans-serif; font-weight: 800; transition: color 0.2s; }
    .post-card:hover .title { color: #e30613; }
    .sep { margin: 0 8px; color: #ddd; font-weight: normal; }
    .comment-link { color: #e30613; font-weight: 800; text-decoration: none; transition: text-decoration 0.2s; }
    .comment-link:hover { text-decoration: underline; }

    /* --- RESPONSIVE --- */
    @media (max-width: 768px) { .page-header h1 { font-size: 2.8rem; } .blog-grid { gap: 20px; } .search-wrapper { padding: 0 10px; } }
</style>