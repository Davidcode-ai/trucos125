---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<a href="/" class="logo-link">
			<div class="css-logo">
				<span class="logo-trucos">TRUCOS</span><span class="logo-125">125</span>
			</div>
		</a>
		
		<div class="internal-links">
			<HeaderLink href="/">Inicio</HeaderLink>
			<HeaderLink href="/blog">Artículos</HeaderLink>
			<HeaderLink href="/sobre-mi">Sobre mí</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: #111; /* Fondo negro Racing */
		box-shadow: 0 2px 8px rgba(0,0,0,0.5);
		position: sticky; /* Se queda fijo arriba al hacer scroll */
		top: 0;
		z-index: 100;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1280px;
		margin: 0 auto;
		height: 80px; /* Altura fija del menú */
	}

	/* --- ESTILOS DEL LOGO POR CÓDIGO --- */
	.logo-link {
		text-decoration: none;
	}

	.css-logo {
		font-family: 'Barlow Condensed', sans-serif;
		font-size: 2.4rem;
		font-weight: 900;
		text-transform: uppercase;
		font-style: italic; /* Da sensación de movimiento y velocidad */
		letter-spacing: -1px; /* Letras un poco más juntas, más agresivo */
		display: flex;
		align-items: center;
		transition: transform 0.2s ease;
	}

	.logo-link:hover .css-logo {
		transform: scale(1.05) skewX(-5deg); /* Efecto "acelerón" al pasar el ratón */
	}

	.logo-trucos {
		color: #ffffff; /* Blanco puro */
	}

	.logo-125 {
		color: #e30613; /* Rojo Racing */
	}

	/* --- ENLACES DEL MENÚ --- */
	.internal-links {
		display: flex;
		gap: 1em;
	}

	nav :global(a) {
		padding: 10px 15px;
		color: #fff;
		text-decoration: none;
		font-family: 'Barlow Condensed', sans-serif;
		text-transform: uppercase;
		font-weight: 700;
		font-size: 1.1rem;
		border-bottom: 4px solid transparent;
		transition: all 0.2s;
	}

	nav :global(a:hover),
	nav :global(a.active) {
		color: #e30613; /* Rojo Racing */
		border-bottom-color: #e30613;
	}

	/* --- RESPONSIVE MÓVIL --- */
	@media (max-width: 768px) {
		nav {
			height: 60px; /* Menú más estrecho en móvil */
		}
		.css-logo {
			font-size: 1.8rem; /* Logo más pequeño para que quepa bien en el móvil */
		}
		.internal-links {
			gap: 5px;
		}
		nav :global(a) {
			padding: 5px 8px;
			font-size: 0.9rem;
		}
	}
</style>