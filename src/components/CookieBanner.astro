---
// src/components/CookieBanner.astro
---

<div id="cookie-banner" class="cookie-banner hidden" aria-live="polite">
  <div class="cookie-content">
    <p>
      Utilizamos cookies propias y de terceros (Google AdSense) para analizar el tráfico y mostrarte publicidad personalizada. Puedes aceptarlas todas o rechazarlas. Más info en nuestra <a href="/privacidad">Política de Privacidad</a>.
    </p>
    <div class="cookie-buttons">
      <button id="accept-cookies" class="btn-accept">Aceptar todas</button>
      <button id="reject-cookies" class="btn-reject">Rechazar</button>
    </div>
  </div>
</div>

<script is:inline>
  // --- LÓGICA DE BLOQUEO Y CONSENTIMIENTO (REFACTORIZADA PARA VIEW TRANSITIONS) ---

  // Elementos del DOM
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('accept-cookies');
  const rejectBtn = document.getElementById('reject-cookies');
  
  // ID de AdSense
  const adsenseClientId = "ca-pub-0000000000000000"; 

  // Función para cargar AdSense
  function loadAdSense() {
    if (document.querySelector('script[src*="pagead2.googlesyndication.com"]')) return;
    const script = document.createElement('script');
    script.src = `https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClientId}`;
    script.async = true;
    script.crossOrigin = "anonymous";
    document.head.appendChild(script);
  }

  // Función para decidir si mostrar el banner o cargar anuncios
  function showBannerIfNeeded() {
    const consentStatus = localStorage.getItem('cookieConsent');
    
    if (consentStatus === 'accepted') {
      loadAdSense();
    } else if (consentStatus === null) {
      // Si es la primera visita (o no hay consentimiento), mostramos el banner
      if (banner) {
        banner.classList.remove('hidden');
      }
    }
  }

  // Event listeners para los botones (solo se añaden una vez)
  acceptBtn?.addEventListener('click', () => {
    localStorage.setItem('cookieConsent', 'accepted');
    banner?.classList.add('hidden');
    loadAdSense(); 
  });

  rejectBtn?.addEventListener('click', () => {
    localStorage.setItem('cookieConsent', 'rejected');
    banner?.classList.add('hidden');
  });

  // --- EJECUCIÓN ---
  // 1. Ejecutar al cargar la página por primera vez
  showBannerIfNeeded();
  
  // 2. Ejecutar en cada navegación del cliente (View Transitions)
  document.addEventListener('astro:page-load', showBannerIfNeeded);
</script>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    background-color: #1e293b;
    color: #f8fafc;
    padding: 1rem;
    z-index: 9999;
    box-shadow: 0 -4px 10px rgba(0, 0, 0, 0.15);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    transform: translateY(0);
  }
  
  .cookie-banner.hidden {
    transform: translateY(100%);
    pointer-events: none;
  }
  
  .cookie-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  
  @media (min-width: 768px) {
    .cookie-content {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
  
  .cookie-content p { margin: 0; }
  .cookie-content a { color: #38bdf8; text-decoration: underline; font-weight: 600; }
  
  .cookie-buttons {
    display: flex;
    gap: 0.75rem;
    width: 100%;
    justify-content: center;
  }
  
  @media (min-width: 768px) {
    .cookie-buttons { width: auto; }
  }
  
  button {
    padding: 0.6rem 1.2rem;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.9rem;
    transition: opacity 0.2s;
    flex: 1;
  }
  
  button:hover { opacity: 0.85; }
  .btn-accept { background-color: #3b82f6; color: white; }
  .btn-reject { background-color: #475569; color: white; }
</style>