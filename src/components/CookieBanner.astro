---
// src/components/CookieBanner.astro
---

<div id="cookie-overlay" class="cookie-overlay hidden">
  <!-- Banner principal -->
  <div id="cookie-banner" class="cookie-box">
    <h2>Uso de Cookies 🍪</h2>
    <p>Utilizamos cookies propias y de terceros (como Google AdSense) para analizar el tráfico y mostrar publicidad personalizada. Puedes aceptarlas todas, configurarlas o rechazarlas.</p>
    
    <div class="cookie-buttons">
      <button id="btn-accept-all" class="btn btn-primary">Aceptar Todas</button>
      <button id="btn-config" class="btn btn-secondary">Configurar</button>
      <button id="btn-reject" class="btn btn-danger">Rechazar</button>
    </div>
  </div>

  <!-- Modal de configuración -->
  <div id="cookie-settings" class="cookie-box hidden">
    <h2>Configuración de Cookies</h2>
    <p>Selecciona qué cookies quieres permitir:</p>
    
    <div class="cookie-option">
      <div class="cookie-option-text">
        <strong>Técnicas (Necesarias)</strong>
        <span>Imprescindibles para que la web funcione (no se pueden desactivar).</span>
      </div>
      <input type="checkbox" checked disabled />
    </div>
    
    <div class="cookie-option">
      <div class="cookie-option-text">
        <strong>Analíticas</strong>
        <span>Nos ayudan a saber cuánta gente nos visita (estadísticas).</span>
      </div>
      <input type="checkbox" id="chk-analytics" checked />
    </div>

    <div class="cookie-option">
      <div class="cookie-option-text">
        <strong>Marketing (Google AdSense)</strong>
        <span>Para mostrar contenido o anuncios relevantes para ti.</span>
      </div>
      <input type="checkbox" id="chk-marketing" checked />
    </div>

    <div class="cookie-buttons mt-4">
      <button id="btn-save-settings" class="btn btn-primary">Guardar Preferencias</button>
      <button id="btn-back-settings" class="btn btn-secondary">Atrás</button>
    </div>
  </div>

</div>

<script is:inline>
  // Usamos tu ID de AdSense real
  const adsenseClientId = "ca-pub-3576421202416487"; 

  function loadAdSense() {
    if (document.querySelector('script[src*="pagead2.googlesyndication.com"]')) return;
    const script = document.createElement('script');
    script.src = `https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClientId}`;
    script.async = true;
    script.crossOrigin = "anonymous";
    document.head.appendChild(script);
  }

  function initCookieBanner() {
    const overlay = document.getElementById('cookie-overlay');
    const banner = document.getElementById('cookie-banner');
    const settings = document.getElementById('cookie-settings');
    
    if (!overlay || !banner || !settings) return;

    const btnAcceptAll = document.getElementById('btn-accept-all');
    const btnReject = document.getElementById('btn-reject');
    const btnConfig = document.getElementById('btn-config');
    const btnSaveSettings = document.getElementById('btn-save-settings');
    const btnBackSettings = document.getElementById('btn-back-settings');

    const chkAnalytics = document.getElementById('chk-analytics');
    const chkMarketing = document.getElementById('chk-marketing');

    const consent = localStorage.getItem('cookieConsent');
    
    // Reseteamos el estado visual por si navegamos con ViewTransitions
    overlay.classList.add('hidden');
    banner.classList.add('hidden');
    settings.classList.add('hidden');
    document.body.style.overflow = '';

    // Comprobamos la decisión del usuario
    if (!consent) {
      // Sin decisión: mostramos banner pero permitimos navegación/scroll (Anti-bot block)
      overlay.classList.remove('hidden');
      banner.classList.remove('hidden');
    } else if (consent === 'rejected') {
      // Rechazadas: ocultar todo, no cargar AdSense
      overlay.classList.add('hidden');
    } else {
      // Aceptadas (all o custom): liberamos scroll y cargamos scripts
      if (consent === 'all' || (consent === 'custom' && localStorage.getItem('cookieMarketing') === 'true')) {
        loadAdSense();
      }
    }

    // Asignamos eventos con .onclick para asegurar que siempre funcionen
    if (btnAcceptAll) btnAcceptAll.onclick = () => {
      localStorage.setItem('cookieConsent', 'all');
      localStorage.setItem('cookieAnalytics', 'true');
      localStorage.setItem('cookieMarketing', 'true');
      overlay.classList.add('hidden');
      document.body.style.overflow = '';
      loadAdSense();
    };

    if (btnReject) btnReject.onclick = () => {
      localStorage.setItem('cookieConsent', 'rejected');
      localStorage.setItem('cookieAnalytics', 'false');
      localStorage.setItem('cookieMarketing', 'false');
      overlay.classList.add('hidden');
      document.body.style.overflow = '';
    };

    if (btnConfig) btnConfig.onclick = () => {
      banner.classList.add('hidden');
      settings.classList.remove('hidden');
    };

    if (btnSaveSettings) btnSaveSettings.onclick = () => {
      localStorage.setItem('cookieConsent', 'custom');
      localStorage.setItem('cookieAnalytics', chkAnalytics.checked);
      localStorage.setItem('cookieMarketing', chkMarketing.checked);
      overlay.classList.add('hidden');
      document.body.style.overflow = '';
      if (chkMarketing.checked) {
         loadAdSense();
      }
    };

    if (btnBackSettings) btnBackSettings.onclick = () => {
      settings.classList.add('hidden');
      banner.classList.remove('hidden');
    };

    function closeOverlay() {
      overlay.classList.add('hidden');
      document.body.style.overflow = '';
    }

    // Exponer función global para abrir el panel de configuración desde cualquier parte
    window.openCookieSettings = () => {
      overlay.classList.remove('hidden');
      banner.classList.add('hidden');
      settings.classList.remove('hidden');
      // No bloqueamos scroll (mejor usabilidad y SEO)
      document.body.style.overflow = '';
    };
  }

  // Inicializar en la carga inicial y en la navegación de Astro
  initCookieBanner();
  document.addEventListener('astro:page-load', initCookieBanner);
</script>

<style>
  /* Contenedor transparente en la parte inferior para no incordiar/bloquear bots */
  .cookie-overlay {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    z-index: 999999;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 1.5rem;
    pointer-events: none; /* Permite clic hacia el contenido web trasero */
    animation: cookieSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes cookieSlideUp {
    from { transform: translateY(120%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .cookie-overlay.hidden {
    display: none !important;
  }
  
  /* Cajas de diálogo (Glassmorphism + Bordes Suaves) */
  .cookie-box {
    pointer-events: auto; /* Reactiva los clics dentro de la caja */
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(12px);
    max-width: 650px;
    width: 100%;
    padding: 28px 32px;
    border-radius: 20px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.15), 0 0 0 1px rgba(0,0,0,0.06);
    font-family: 'Roboto', sans-serif;
    color: #333;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .cookie-box.hidden {
    display: none;
  }

  .cookie-box h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2.2rem;
    margin-top: 0;
    margin-bottom: 8px;
    color: #111;
    text-transform: uppercase;
    font-weight: 700;
  }

  .cookie-box p {
    font-size: 1.05rem;
    color: #444;
    line-height: 1.6;
    margin-bottom: 0; /* Let flex gap handle spacing */
  }

  /* Botones (Diseño en forma de Píldora / Moderno) */
  .cookie-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: flex-end;
    margin-top: 8px;
  }

  .btn {
    padding: 12px 24px;
    border: none;
    border-radius: 50px;
    font-size: 1.05rem;
    font-weight: bold;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    font-family: 'Barlow Condensed', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }
  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0,0,0,0.15);
  }

  .btn-primary { 
    background: linear-gradient(135deg, #e30613, #b3040f); 
    color: #fff; 
  }
  .btn-primary:hover { 
    background: linear-gradient(135deg, #f00b1a, #c40511); 
  }
  
  .btn-secondary { 
    background: #f8f9fa; 
    color: #333; 
    border: 1px solid #e0e0e0; 
  }
  .btn-secondary:hover { 
    background: #ebebeb; 
  }

  .btn-danger { 
    background: #222; 
    color: #fff; 
  }
  .btn-danger:hover { 
    background: #000; 
  }

  /* Opciones de configuración (Sleek List) */
  .cookie-option {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
    border-bottom: 1px solid #eaeaea;
  }
  .cookie-option:last-of-type { border-bottom: none; }

  .cookie-option-text {
    display: flex;
    flex-direction: column;
    padding-right: 20px;
  }
  .cookie-option-text strong { 
    color: #111; 
    font-size: 1.1rem; 
    font-weight: 600;
  }
  .cookie-option-text span { 
    color: #666; 
    font-size: 0.95rem; 
    margin-top: 6px; 
    line-height: 1.4;
  }

  .mt-4 { margin-top: 25px; }

  /* Checkboxes mejorados */
  input[type="checkbox"] {
    width: 22px;
    height: 22px;
    cursor: pointer;
    accent-color: #e30613;
    border-radius: 6px;
  }
  
  @media (max-width: 600px) {
    .cookie-overlay {
      padding: 1rem;
    }
    .cookie-buttons { 
      flex-direction: column; 
    }
    .btn { 
      width: 100%; 
      text-align: center; 
    }
  }
</style>