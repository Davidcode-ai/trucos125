---
const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} trucos125.com. Todos los derechos reservados.
	
	<div class="legal-links">
		<a href="/aviso-legal">Aviso Legal</a>
		<span>|</span>
		<a href="/privacidad">Política de Privacidad</a>
		<span>|</span>
		<a href="/cookies">Política de Cookies</a>
	</div>
</footer>

<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-light) 0%, transparent 100%);
		color: rgb(var(--gray));
		text-align: center;
	}
	.legal-links {
		display: flex;
		justify-content: center;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.5em 1em;
		margin-top: 1em;
		font-size: 0.85em;
	}
	.legal-links a {
		color: rgb(var(--gray));
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.legal-links a:hover {
		color: rgb(var(--black));
		text-decoration: underline;
	}
	.legal-links span {
		color: rgb(var(--gray-light));
	}
</style>