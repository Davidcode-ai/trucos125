<script>
    document.addEventListener('astro:page-load', () => {
        const scrollTopBtn = document.getElementById('scrollTopBtn');
        if (scrollTopBtn) {
            scrollTopBtn.addEventListener('click', () => {
                window.scrollTo({
                    top: 0,
                    behavior: 'smooth'
                });
            });
        }
    });
</script>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const form = document.querySelector('form[action*="mailerlite"]');
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault(); // Evita que la página cambie al JSON
        
        const formData = new FormData(form);
        
        fetch(form.action, {
          method: 'POST',
          body: formData,
          mode: 'no-cors' // Crucial para evitar bloqueos de seguridad cruzada
        }).then(() => {
          alert('¡Gracias por suscribirte a La Revista!');
          form.reset(); // Vacía la caja de texto
        }).catch(error => {
          console.error('Error al suscribirse:', error);
        });
      });
    }
  });
</script>

<style>
    /* RESET FOOTER */
    .site-footer {
        width: 100%;
        margin-top: 60px;
        font-family: var(--font-body);
    }
    
    /* ZONA MEGA (Fondo Claro) */
    .footer-mega {
        background-color: #f4f5f6; /* Gris muy clarito estilo Xataka */
        padding: 50px 0;
        border-top: 2px solid #eaeaea;
    }
    
    .footer-container {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 20px;
        display: flex;
        justify-content: space-between;
        gap: 60px;
    }

    /* LATERAL IZQUIERDO (TOPICS) */
    .footer-topics {
        flex: 1;
    }
    .footer-topics h2 {
        font-family: var(--font-title);
        font-size: 1.2rem;
        color: #111;
        margin-bottom: 25px;
        text-transform: none;
        letter-spacing: -0.02em;
        font-weight: 800;
    }

    .topics-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .topic-column {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .topic-column a {
        color: #555;
        font-size: 0.95rem;
        text-decoration: none;
        transition: color 0.2s;
        font-family: var(--font-body);
    }
    .topic-column a:hover {
        color: var(--moto-red);
    }

    .btn-more-topics {
        display: inline-block;
        background-color: #444c56; /* Gris oscuro azulado */
        color: #fff;
        font-family: var(--font-title);
        font-size: 0.8rem;
        font-weight: 700;
        padding: 8px 16px;
        border-radius: 4px;
        text-decoration: none;
        letter-spacing: 0.05em;
        transition: background-color 0.2s;
    }
    .btn-more-topics:hover {
        background-color: #222;
    }

    /* LATERAL DERECHO (NEWSLETTER) */
    .footer-subscribe {
        flex: 1;
        max-width: 500px;
    }
    .footer-subscribe h2 {
        font-family: var(--font-title);
        font-size: 1.1rem;
        color: #111;
        margin-bottom: 10px;
        text-transform: uppercase;
        font-weight: 800;
        letter-spacing: 0;
    }

    .newsletter-desc {
        font-size: 0.95rem;
        color: #555;
        margin-bottom: 20px;
        line-height: 1.5;
    }

    .newsletter-form {
        display: flex;
        margin-bottom: 15px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05); /* Sombra sutil revista */
    }
    .newsletter-form input {
        flex: 1;
        padding: 12px 15px;
        border: 2px solid #111;
        border-right: none;
        border-radius: 4px 0 0 4px;
        font-family: var(--font-body);
        font-size: 1rem;
        outline: none;
        transition: border-color 0.2s;
    }
    .newsletter-form input:focus {
        border-color: #e30613;
    }
    .newsletter-form button {
        background-color: #e30613;
        color: #fff;
        border: 2px solid #e30613;
        padding: 0 20px;
        font-family: var(--font-title);
        font-weight: 800;
        font-size: 0.95rem;
        border-radius: 0 4px 4px 0;
        cursor: pointer;
        transition: background-color 0.2s, border-color 0.2s;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .newsletter-form button:hover {
        background-color: #111;
        border-color: #111;
    }

    .privacy-note {
        font-size: 0.8rem;
        color: #777;
        margin-bottom: 30px;
    }
    .privacy-note a {
        color: #777;
        text-decoration: underline;
    }

    .social-block {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 30px;
    }
    .follow-text {
        color: #555;
        font-size: 0.9rem;
    }
    .social-icons {
        display: flex;
        gap: 12px;
        align-items: center;
    }
    .social-icons a {
        color: #555;
        display: flex;
        align-items: center;
        transition: transform 0.2s;
    }
    .social-icons a:hover {
        transform: scale(1.15);
    }

    .footer-corp {
        background-color: #111;
        padding: 20px 0;
    }

    .corp-container {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .corp-center {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 5px;
        flex-grow: 1;
    }

    .legal-links {
        display: flex;
        gap: 20px;
        justify-content: center;
    }
    .legal-links a {
        color: #aaa;
        font-size: 0.85rem;
        text-decoration: none;
        transition: color 0.2s;
    }
    .legal-links a:hover {
        color: #fff;
    }

    .corp-center p {
        margin: 0;
        font-size: 0.8rem;
        color: #666;
    }

    .corp-right-btn {
        flex-shrink: 0;
    }

    .btn-scroll-top {
        background-color: #333;
        color: #fff;
        border: none;
        padding: 8px 16px;
        border-radius: 4px;
        font-family: var(--font-title);
        font-size: 0.75rem;
        font-weight: 700;
        cursor: pointer;
        transition: background-color 0.2s;
        letter-spacing: 0.05em;
    }
    .btn-scroll-top:hover {
        background-color: #555;
    }

    /* RESPONSIVE */
    @media (max-width: 900px) {
        .footer-container {
            flex-direction: column;
            gap: 40px;
        }
        .footer-subscribe {
            max-width: 100%;
        }
    }

    @media (max-width: 600px) {
        .topics-grid {
            grid-template-columns: 1fr 1fr;
        }
        .corp-container {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
        .corp-center {
            align-items: center;
        }
        .newsletter-form {
            flex-direction: column;
        }
        .newsletter-form input {
            border-radius: 4px;
            border-right: 1px solid #ddd;
            margin-bottom: 10px;
        }
        .newsletter-form button {
            border-radius: 4px;
            padding: 12px;
        }
    }
</style>