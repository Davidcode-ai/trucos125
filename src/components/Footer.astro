<style>
    .site-footer {
        background-color: #111;
        color: #f8f9fa;
        padding: 40px 20px;
        margin-top: 60px;
        text-align: center;
        border-top: 5px solid #e30613;
    }
    .footer-content {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 15px;
    }
    
    /* ESTILOS DE LOS BOTONES SOCIALES */
    .social-links {
        display: flex;
        gap: 20px;
        margin-bottom: 10px;
        align-items: center;
        justify-content: center;
    }
    .social-links a {
        color: #f8f9fa;
        transition: transform 0.3s ease, color 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .social-links a:hover {
        color: #e30613; /* Tu rojo racing */
        transform: translateY(-5px) scale(1.1); /* Efecto salto al pasar el ratón */
    }

    p {
        margin: 0;
        font-size: 1rem;
        color: #ccc;
    }
    .legal-links {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
    }
    .legal-links a {
        color: #999;
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.2s ease;
    }
    .legal-links a:hover {
        color: #e30613;
    }
    .separator {
        color: #555;
    }
</style>