---
// Componente Newsletter - trucos125.com (Conectado a MailerLite)
---
<div class="newsletter-card ml-subscribe-form-38378151">
  
  <div class="content row-form">
    <span class="badge">COMUNIDAD TRUCOS125</span>
    <h3>¡No te pierdas ni un truco!</h3>
    <p>Únete a más de 500 moteros novatos y recibe consejos de mecánica, seguridad y ofertas en equipamiento cada semana.</p>
    
    <form class="newsletter-form ml-block-form" action="https://assets.mailerlite.com/jsonp/2184945/forms/181752705366099123/subscribe" method="post">      
      <input type="email" name="fields[email]" placeholder="Tu mejor email..." required autocomplete="email" />
      
      <input type="hidden" name="ml-submit" value="1">
      <input type="hidden" name="anticsrf" value="true">
      
      <button type="submit" class="primary">¡QUIERO UNIRME!</button>
      
      <button disabled="disabled" style="display: none;" type="button" class="loading">
        Enviando...
      </button>
    </form>
    <p class="spam-free">🔒 Sin spam. Solo gas del bueno.</p>
  </div>

  <div class="content row-success" style="display: none;">
    <span class="badge">¡BINGO!</span>
    <h3>¡Bienvenido a la familia!</h3>
    <p>Te acabas de suscribir con éxito. Revisa tu bandeja de entrada (y la de spam por si acaso), en breve recibirás noticias.</p>
  </div>

</div>

<style>
  /* --- LOS MISMOS ESTILOS RACING DE SIEMPRE --- */
  .newsletter-card {
    background: #111;
    color: white;
    padding: 3rem 2rem;
    border-radius: 20px;
    margin: 4rem 0;
    text-align: center;
    border-left: 8px solid #e30613;
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
  }
  .badge { background: #e30613; padding: 5px 12px; font-weight: 900; font-size: 0.8rem; border-radius: 4px; display: inline-block; margin-bottom: 10px;}
  h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 2.5rem; margin: 0 0 1rem 0; text-transform: uppercase; }
  p { font-size: 1.1rem; color: #ccc; max-width: 600px; margin: 0 auto 2rem; }
  
  .newsletter-form {
    display: flex;
    gap: 10px;
    justify-content: center;
    max-width: 500px;
    margin: 0 auto;
  }
  
  input {
    flex: 1;
    padding: 1rem;
    border-radius: 8px;
    border: none;
    font-size: 1rem;
    color: #111;
  }
  
  button.primary {
    background: #e30613;
    color: white;
    border: none;
    padding: 0 1.5rem;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 1.2rem;
    border-radius: 8px;
    cursor: pointer;
    transition: transform 0.2s;
  }
  
  button.primary:hover { transform: scale(1.05); background: #be123c; }
  .spam-free { font-size: 0.8rem; margin-top: 1rem; opacity: 0.6; }

  @media (max-width: 600px) {
    .newsletter-form { flex-direction: column; }
    button.primary { padding: 1rem; }
  }
  /* --- AJUSTES EXTRA PARA MÓVIL (NEWSLETTER) --- */
  @media (max-width: 768px) {
    .newsletter-card {
      padding: 2rem 1.5rem; /* Reducimos el relleno asfixiante */
      margin: 2rem 10px; /* Le damos un poco de aire por los lados */
      border-left-width: 4px; /* Borde más fino en móvil */
      box-sizing: border-box; /* Vital para que no se salga de la pantalla */
    }
    h3 {
      font-size: 2rem; /* Título un pelín más pequeño */
    }
    .newsletter-form { 
      flex-direction: column; 
      width: 100%;
    }
    input {
      width: 100%;
      box-sizing: border-box;
    }
    button.primary { 
      width: 100%;
      padding: 1rem; 
    }
  }
</style>

<script>
  // Interceptamos el formulario para que no nos saque de la web
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector('.newsletter-form');
    
    // Comprobamos que el formulario existe y es de tipo Formulario
    if (form instanceof HTMLFormElement) {
      form.addEventListener('submit', (e) => {
        e.preventDefault(); // Cortamos de raíz que te envíe a la página blanca
        
        const actionUrl = form.getAttribute('action') || '';
        const formData = new FormData(form);
        const btn = form.querySelector('button.primary');
        
        // Comprobamos que el botón existe y es de tipo Botón
        if (btn instanceof HTMLButtonElement) {
            // Cambiamos el texto del botón para que parezca que carga
            const originalText = btn.innerHTML;
            btn.innerHTML = 'Enviando...';
            btn.disabled = true;

            // Enviamos los datos por detrás sin recargar
            fetch(actionUrl, {
              method: 'POST',
              body: formData,
              mode: 'no-cors' // Esto es vital para que MailerLite lo acepte
            }).then(() => {
              // Buscamos las cajas de contenido
              const rowForm = document.querySelector('.row-form');
              const rowSuccess = document.querySelector('.row-success');
              
              // Si existen, les cambiamos el estilo (ocultar una y mostrar otra)
              if (rowForm instanceof HTMLElement) rowForm.style.display = 'none';
              if (rowSuccess instanceof HTMLElement) rowSuccess.style.display = 'block';
              
            }).catch((err) => {
              console.error(err);
              btn.innerHTML = originalText;
              btn.disabled = false;
            });
        }
      });
    }
  });
</script>