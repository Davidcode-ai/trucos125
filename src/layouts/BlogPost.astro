---
import Newsletter from '../components/Newsletter.astro';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import CookieBanner from '../components/CookieBanner.astro';
import { Image } from 'astro:assets'; // <-- IMPORTAMOS LA MAGIA AQUÍ

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="es">
    <head>
        <BaseHead title={title} description={description} />
        <style>
            /* Reset y contenedor general */
            main {
                width: 100%;
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }
            
            /* Contenedor central ancho para PC */
            article {
                width: 100%;
                max-width: 950px; /* Tamaño generoso en PC */
                margin: 0 auto;
                padding: 2rem 1.5rem;
                box-sizing: border-box;
                animation: fadeUp 0.6s ease-out forwards;
            }

            .hero-image {
                width: 100%;
            }
            .hero-image img {
                display: block;
                margin: 0 auto;
                border-radius: 12px;
                box-shadow: 0 4px 15px rgba(0,0,0,0.1);
                width: 100%;
                height: auto;
            }

            /* Texto grande y legible para PC */
            .prose {
                width: 100%;
                margin: auto;
                padding: 1em 0;
                color: #222;
                font-size: 20px; /* Tamaño de lectura profesional */
                line-height: 1.8;
            }
            
            /* Arreglo imágenes dentro del artículo */
            .prose :global(img) {
                max-width: 100% !important;
                height: auto !important;
                border-radius: 12px;
                box-shadow: 0 4px 15px rgba(0,0,0,0.1);
                margin: 2rem auto;
                display: block;
            }

            .title {
                margin-bottom: 2rem;
                padding: 1em 0;
                text-align: center;
                line-height: 1.1;
            }
            .title h1 {
                margin: 0 0 0.5em 0;
                font-size: 3rem;
                font-family: 'Barlow Condensed', sans-serif;
                font-weight: 900;
                text-transform: uppercase;
            }
            .date {
                margin-bottom: 0.5em;
                color: rgb(var(--gray));
                font-size: 1.1rem;
            }
            .last-updated-on {
                font-style: italic;
            }

            /* --- ANIMACIÓN PREMIUM DE ENTRADA --- */
            @keyframes fadeUp {
                from { opacity: 0; transform: translateY(30px); }
                to { opacity: 1; transform: translateY(0); }
            }

            /* --- ARREGLOS DEFINITIVOS PARA MÓVIL --- */
            @media (max-width: 768px) {
                body {
                    overflow-x: hidden; 
                }
                article {
                    padding: 1rem 15px !important;
                }
                .hero-image {
                    margin: 0 0 20px 0;
                }
                .hero-image img {
                    border-radius: 0;
                }
                .prose {
                    font-size: 18px !important; /* En móvil un poco más pequeño */
                    padding: 0; 
                }
                .title h1 {
                    font-size: 2.2rem;
                    line-height: 1.1;
                    margin: 0.5em 0;
                    word-wrap: break-word; 
                }
                .date {
                    margin-bottom: 0.5em;
                }
            }
            /* --- BLINDAJE ANTI-DESBORDAMIENTO (100% RESPONSIVE) --- */
  
            /* 1. Obligamos a TODOS los títulos a partirse si chocan con el borde */
            :global(h1), :global(h2), :global(h3), :global(h4), :global(h5), :global(h6), :global(a) {
                overflow-wrap: break-word !important;
                word-wrap: break-word !important;
                word-break: break-word !important;
                max-width: 100% !important;
                hyphens: auto;
            }
        
            /* 2. Textos elásticos mágicos para móvil */
            @media (max-width: 768px) {
                /* El título principal del artículo */
                .title h1 {
                    font-size: clamp(1.8rem, 8vw, 2.5rem) !important; 
                    line-height: 1.1 !important;
                }
                
                /* Los subtítulos dentro del texto (H2 y H3) */
                .prose :global(h2) {
                    font-size: clamp(1.5rem, 6vw, 2rem) !important;
                    line-height: 1.2 !important;
                }
                
                .prose :global(h3) {
                    font-size: clamp(1.3rem, 5vw, 1.7rem) !important;
                }
            }
        </style>
    </head>

    <body>
        <Header />
        <main>
            <article>
                <div class="hero-image">
                    {heroImage && (
                        <Image 
                            src={heroImage} 
                            alt={title} 
                            width={1020} 
                            height={510} 
                            format="webp"
                            loading="eager"
                        />
                    )}
                </div>
                <div class="prose">
                    <div class="title">
                        <div class="date">
                            <FormattedDate date={pubDate} />
                            {
                                updatedDate && (
                                    <div class="last-updated-on">
                                        (Actualizado: <FormattedDate date={updatedDate} />)
                                    </div>
                                )
                            }
                        </div>
                        <h1>{title}</h1>
                        <hr />
                    </div>
                    <slot />

                    <div id="disqus_thread" style="margin-top: 60px; padding-top: 30px; border-top: 4px solid #e30613;"></div>
                <script is:inline>
                    // Le decimos al navegador que ejecute esto cada vez que Astro carga una nueva vista
                    document.addEventListener('astro:page-load', () => {

                        // Si no hay caja de comentarios en esta página, no hacemos nada
                        const disqusThread = document.getElementById('disqus_thread');
                        if (!disqusThread) return;
                    
                        // Si Disqus ya estaba cargado de antes, lo reseteamos con la nueva URL
                        if (window.DISQUS) {
                            window.DISQUS.reset({
                                reload: true,
                                config: function () {
                                    this.page.url = window.location.href;
                                    this.page.identifier = window.location.pathname;
                                }
                            });
                        } else {
                            // Si es la primera vez que entramos, cargamos el script desde cero
                            var d = document, s = d.createElement('script');
                            s.src = 'https://trucos125.disqus.com/embed.js'; // Tu enlace de Disqus
                            s.setAttribute('data-timestamp', +new Date());
                            (d.head || d.body).appendChild(s);
                        }
                    });
                </script>
                    <noscript>Por favor, activa JavaScript para ver los <a href="https://disqus.com/?ref_noscript">comentarios.</a></noscript>
                    <Newsletter />
                    <div style="margin-top: 3rem; padding: 1rem; background: #f0f0f0; border-radius: 8px; text-align: center; font-size: 0.9em;">
                        <p>¿Te ha servido este truco? <a href="/blog">Lee más artículos aquí</a>.</p>
                    </div>
                </div>
            </article>
        </main>
        <Footer />
        <CookieBanner />
  </body>
</html>