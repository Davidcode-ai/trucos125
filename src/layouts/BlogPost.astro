---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import CookieBanner from '../components/CookieBanner.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import Adsense from '../components/Adsense.astro';
import { Image } from 'astro:assets'; 

type Props = CollectionEntry<'blog'>['data'];

// 👇 1. Extraemos la "categoria" aquí 👇
const { title, description, pubDate, updatedDate, heroImage, categoria } = Astro.props;

// 👇 2. Limpiamos la URL (Quita acentos: "Mecánica" -> "mecanica") 👇
const categoryUrl = categoria 
  ? `/${categoria.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "")}` 
  : '';
---

<html lang="es">
    <head>
        <BaseHead title={title} description={description} />
        <style>
            /* Reset y contenedor general */
            main {
                width: 100%;
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }
            
            /* Contenedor central ancho para PC */
            article {
                width: 100%;
                max-width: 950px; 
                margin: 0 auto;
                padding: 2rem 1.5rem;
                box-sizing: border-box;
                animation: fadeUp 0.6s ease-out forwards;
            }

            .hero-image {
                width: 100%;
            }
            .hero-image img {
                display: block;
                margin: 0 auto;
                border-radius: 12px;
                box-shadow: 0 4px 15px rgba(0,0,0,0.1);
                width: 100%;
                height: auto;
            }

            /* Texto grande y legible para PC */
            .prose {
                width: 100%;
                margin: auto;
                padding: 1em 0;
                color: #222;
                font-size: 20px; 
                line-height: 1.8;
            }
            
            /* Arreglo imágenes dentro del artículo */
            .prose :global(img) {
                max-width: 100% !important;
                height: auto !important;
                border-radius: 12px;
                box-shadow: 0 4px 15px rgba(0,0,0,0.1);
                margin: 2rem auto;
                display: block;
            }

            .title {
                margin-bottom: 2rem;
                padding: 1em 0;
                text-align: center;
                line-height: 1.1;
            }
            .title h1 {
                margin: 0 0 0.5em 0;
                font-size: 3rem;
                font-family: var(--font-title);
                font-weight: 800;
                letter-spacing: -0.02em;
            }
            .date {
                margin-bottom: 0.5em;
                color: rgb(var(--gray));
                font-size: 1.1rem;
            }
            .last-updated-on {
                font-style: italic;
            }

            /* 👇 3. ESTILOS DE LA ETIQUETA DE CATEGORÍA 👇 */
            .post-category-badge {
                display: inline-block;
                background-color: var(--moto-red);
                color: #ffffff !important;
                padding: 4px 10px;
                border-radius: 2px;
                font-family: var(--font-title);
                font-size: 0.8rem;
                letter-spacing: 0.05em;
                font-weight: 700;
                text-transform: uppercase;
                text-decoration: none;
                margin-bottom: 15px;
                transition: background-color 0.3s ease, transform 0.2s ease;
            }
            .post-category-badge:hover {
                background-color: #111;
                transform: translateY(-2px);
            }

            /* --- ANIMACIÓN PREMIUM DE ENTRADA --- */
            @keyframes fadeUp {
                from { opacity: 0; transform: translateY(30px); }
                to { opacity: 1; transform: translateY(0); }
            }

            /* --- ARREGLOS DEFINITIVOS PARA MÓVIL --- */
            @media (max-width: 768px) {
                body {
                    overflow-x: hidden; 
                }
                article {
                    padding: 1rem 15px !important;
                }
                .hero-image {
                    margin: 0 0 20px 0;
                }
                .hero-image img {
                    border-radius: 0;
                }
                .prose {
                    font-size: 18px !important; 
                    padding: 0; 
                }
                .title h1 {
                    font-size: 2.2rem;
                    line-height: 1.1;
                    margin: 0.5em 0;
                    word-wrap: break-word; 
                }
                .date {
                    margin-bottom: 0.5em;
                }
            }
            
            /* --- BLINDAJE ANTI-DESBORDAMIENTO (100% RESPONSIVE) --- */
            :global(h1), :global(h2), :global(h3), :global(h4), :global(h5), :global(h6), :global(a) {
                overflow-wrap: break-word !important;
                word-wrap: break-word !important;
                word-break: break-word !important;
                max-width: 100% !important;
                hyphens: auto;
            }
        
            @media (max-width: 768px) {
                .title h1 {
                    font-size: clamp(1.8rem, 8vw, 2.5rem) !important; 
                    line-height: 1.1 !important;
                }
                .prose :global(h2) {
                    font-size: clamp(1.5rem, 6vw, 2rem) !important;
                    line-height: 1.2 !important;
                }
                .prose :global(h3) {
                    font-size: clamp(1.3rem, 5vw, 1.7rem) !important;
                }
            }
        </style>
    </head>

    <body>
        <Header />
        <main>
            <article>
                <div class="hero-image">
                    {heroImage && (
                        <Image 
                            src={heroImage} 
                            alt={title} 
                            width={1020} 
                            height={510} 
                            format="webp"
                            loading="eager"
                        />
                    )}
                </div>
                <div class="prose">
                    <div class="title">
                        
                        {categoria && (
                            <a href={categoryUrl} class="post-category-badge">
                                {categoria}
                            </a>
                        )}

                        <div class="date">
                            <FormattedDate date={pubDate} />
                            {
                                updatedDate && (
                                    <div class="last-updated-on">
                                        (Actualizado: <FormattedDate date={updatedDate} />)
                                    </div>
                                )
                            }
                        </div>
                        <h1>{title}</h1>
                        <hr />
                    </div>
                    
                    <Adsense bloque="in-article" />
                    
                    <slot />
                    
                    <Adsense bloque="display" />
                    
                </div> <!-- Fin de .prose -->

                <div id="disqus_thread" style="margin-top: 60px; padding-top: 30px; border-top: 4px solid #e30613;"></div>
                <script is:inline>
                    document.addEventListener('astro:page-load', () => {
                        const disqusThread = document.getElementById('disqus_thread');
                        if (!disqusThread) return;
                    
                        if (window.DISQUS) {
                            window.DISQUS.reset({
                                reload: true,
                                config: function () {
                                    this.page.url = window.location.href;
                                    this.page.identifier = window.location.pathname;
                                }
                            });
                        } else {
                            var d = document, s = d.createElement('script');
                            s.src = 'https://trucos125.disqus.com/embed.js'; 
                            s.setAttribute('data-timestamp', +new Date());
                            (d.head || d.body).appendChild(s);
                        }
                    });
                </script>
                <noscript>Por favor, activa JavaScript para ver los <a href="https://disqus.com/?ref_noscript">comentarios.</a></noscript>
                <RelatedPosts currentTitle={title} currentCategory={categoria} />
            </article>
        </main>
        <Footer />
        <CookieBanner />
  </body>
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-52J2VS5S" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
</html>