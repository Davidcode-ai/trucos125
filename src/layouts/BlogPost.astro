---
import Newsletter from '../components/Newsletter.astro';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import CookieBanner from '../components/CookieBanner.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="es">
    <head>
        <BaseHead title={title} description={description} />
        <style>
            main {
                width: calc(100% - 2em);
                max-width: 100%;
                margin: 0;
            }
            .hero-image {
                width: 100%;
            }
            .hero-image img {
                display: block;
                margin: 0 auto;
                border-radius: 12px;
                box-shadow: var(--box-shadow);
            }
            .prose {
                width: 720px;
                max-width: calc(100% - 2em);
                margin: auto;
                padding: 1em;
                color: rgb(var(--gray-dark));
            }
            .title {
                margin-bottom: 1em;
                padding: 1em 0;
                text-align: center;
                line-height: 1;
            }
            .title h1 {
                margin: 0 0 0.5em 0;
            }
            .date {
                margin-bottom: 0.5em;
                color: rgb(var(--gray));
            }
            .last-updated-on {
                font-style: italic;
            }
            /* --- ANIMACIÓN PREMIUM DE ENTRADA --- */
            article {
                animation: fadeUp 0.6s ease-out forwards;
            }

            @keyframes fadeUp {
                from { opacity: 0; transform: translateY(30px); }
                to { opacity: 1; transform: translateY(0); }
            }

            /* --- ARREGLOS PARA MÓVIL Y FLUIDEZ --- */
            /* Forzamos a que las imágenes NUNCA se salgan de la pantalla del móvil */
            .prose img {
                max-width: 100% !important;
                height: auto !important;
                border-radius: 12px;
                box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            }

            /* En pantallas de móvil (menos de 768px) ajustamos los márgenes y letras */
            @media (max-width: 768px) {
            main {
                padding: 15px; /* Quitamos los márgenes blancos gigantes */
            }
            .title h1 {
                font-size: 2.2em; /* Título un poco más pequeño para que quepa bien */
                line-height: 1.1;
            }
            .prose {
                width: 100%;
                font-size: 1.05em; /* Letra un pelín más grande para leer mejor en móvil */
            }
            .hero-image {
                margin: -15px -15px 20px -15px; /* Hace que la foto de portada ocupe todo el ancho del móvil */
            }
            .hero-image img {
                border-radius: 0; /* Quitamos bordes redondeados en móvil para que quede a sangre */
            }
            }
        </style>
    </head>

    <body>
        <Header />
        <main>
            <article>
                <div class="hero-image">
					{heroImage && <img width={1020} height={510} src={typeof heroImage === 'object' ? heroImage.src : heroImage} alt="" />}                </div>
                <div class="prose">
                    <div class="title">
                        <div class="date">
                            <FormattedDate date={pubDate} />
                            {
                                updatedDate && (
                                    <div class="last-updated-on">
                                        (Actualizado: <FormattedDate date={updatedDate} />)
                                    </div>
                                )
                            }
                        </div>
                        <h1>{title}</h1>
                        <hr />
                    </div>
                    <slot />
					<Newsletter />
                    <div style="margin-top: 3rem; padding: 1rem; background: #f0f0f0; border-radius: 8px; text-align: center; font-size: 0.9em;">
                        <p>¿Te ha servido este truco? <a href="/blog">Lee más artículos aquí</a>.</p>
                    </div>
                </div>
            </article>
        </main>
        <Footer />
        <CookieBanner />
  </body>
</html>